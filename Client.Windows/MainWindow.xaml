<Window x:Class="Client.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NOX"
        Icon="Assets/Nox.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid x:Name="AppRoot"
          Background="{StaticResource AppBackgroundBrush}">

        <!-- AUTH SCREEN -->
        <Grid x:Name="AuthScreen"
              Visibility="Visible"
              Margin="0">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/login-background.png"
                            Stretch="UniformToFill" />
            </Grid.Background>

            <Grid.ColumnDefinitions>
                

                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="48"
                  Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center"
                            MaxWidth="460">

                    <TextBlock Text="NOX"
                               FontSize="52"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="End-to-End encrypted file transfer"
                               Margin="0,12,0,0"
                               FontSize="21"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="Encrypt locally, send securely, and keep temporary server storage blind."
                               Margin="0,18,0,0"
                               FontSize="15"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Foreground="{StaticResource TextMutedBrush}" />

                    <Border Margin="0,34,0,0"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Zero content knowledge"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Files and private keys stay encrypted before they ever touch the server."
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1"
                  Margin="32,20,46,20">
                <Border Style="{StaticResource PanelBorderStyle}"
                        Background="#E61D2330"
                        Width="396"
                        Height="575"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Accesso"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock Text="-"
                                   FontSize="13"
                                   Margin="0,8,0,24"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Server URL"
                                       FontSize="16"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <Ellipse x:Name="ServerOnlineIndicator"
                                     Width="9"
                                     Height="9"
                                     Margin="8,2,0,0"
                                     Fill="#FF5C5C"
                                     Visibility="Visible" />
                        </StackPanel>
                        <TextBox x:Name="ServerUrlTextBox"
                                 Margin="0,6,0,8"
                                 Text="https://localhost:7003"
                                 TextChanged="ServerUrlTextBox_TextChanged" />

                        <CheckBox x:Name="RememberServerCheckBox"
                                  Content="Ricorda server"
                                  Margin="0,0,0,16"
                                  FontSize="14"
                                  Foreground="{StaticResource TextMutedBrush}"
                                  Unchecked="RememberServerCheckBox_Unchecked" />

                        <TextBlock x:Name="UsernameLabelTextBlock"
                                   Text="Username"
                                   FontSize="17"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBox x:Name="UsernameTextBox"
                                 Margin="0,6,0,16"
                                 Visibility="Collapsed"
                                 IsEnabled="False" />

                        <TextBlock x:Name="PasswordLabelTextBlock"
                                   Text="Password"
                                   FontSize="17"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <PasswordBox x:Name="PasswordBox"
                                     Margin="0,6,0,20"
                                     Height="46"
                                     Visibility="Collapsed"
                                     IsEnabled="False" />

                        <TextBlock x:Name="AuthErrorTextBlock"
                                   Text=""
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14" />

                        <Button x:Name="SignInButton"
                                FontSize="18"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="48"
                                Width="190"
                                Content="Connetti"
                                Click="SignInButton_Click" />

                        <Button x:Name="CreateAccountButton"
                                FontSize="18"
                                Margin="0,12,0,0"
                                Height="49"
                                Width="160"
                                Content="Registrati"
                                Visibility="Collapsed"
                                Background="Transparent"
                                Foreground="{StaticResource TextMutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                Click="CreateAccountButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- MAIN DASHBOARD -->
        <Grid x:Name="MainShell"
              Visibility="Collapsed"
              Margin="34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <DockPanel Grid.Row="0"
                       Margin="0,0,0,22">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="NOX"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="End-to-End encrypted file transfer"
                               Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="TopMyIdentityButton"
                            Height="38"
                            Padding="14,0"
                            Content="Fingerprint"
                            Background="Transparent"
                            Foreground="{StaticResource TextMutedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            Click="TopMyIdentityButton_Click" />

                    <Button x:Name="TopTrustedContactsButton"
                            Height="38"
                            Margin="10,0,0,0"
                            Padding="14,0"
                            Content="Contatti fidati"
                            Background="Transparent"
                            Foreground="{StaticResource TextMutedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            Click="TopTrustedContactsButton_Click" />

                    <Button x:Name="LogoutButton"
                            Height="38"
                            Margin="10,0,18,0"
                            Padding="14,0"
                            Content="Logout"
                            Background="Transparent"
                            Foreground="{StaticResource TextMutedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            Click="LogoutButton_Click" />

                    <TextBlock x:Name="SignedInUserTextBlock"
                               Text="Signed in"
                               VerticalAlignment="Center"
                               FontSize="15"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </DockPanel>

            <!-- CONTENT -->
            <Grid Grid.Row="1">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <TabControl Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TextPrimaryBrush}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="Background" Value="#121722" />
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Padding" Value="16,9" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="FontSize" Value="15" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="TabBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6,6,0,0"
                                                    Padding="{TemplateBinding Padding}"
                                                    Margin="{TemplateBinding Margin}">
                                                <ContentPresenter x:Name="ContentSite"
                                                                  ContentSource="Header"
                                                                  RecognizesAccessKey="True"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="TabBorder" Property="Background" Value="#1D2330" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="Trasferimento file" />
                            </TabItem.Header>

                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Text="Scegli un destinatario e invia file"
                                           Margin="0,0,0,18"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="RecipientUsernameTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,12,0"
                                     Text="Immetti destinatario"
                                     Foreground="{StaticResource TextMutedBrush}"
                                     PreviewMouseDown="RecipientUsernameTextBox_PreviewMouseDown"
                                     GotKeyboardFocus="RecipientUsernameTextBox_GotKeyboardFocus"
                                     LostKeyboardFocus="RecipientUsernameTextBox_LostKeyboardFocus"
                                     TextChanged="RecipientUsernameTextBox_TextChanged" />

                            <ComboBox x:Name="TrustedRecipientsComboBox"
                                      Grid.Column="1"
                                      Margin="0,0,12,0"
                                      Height="46"
                                      Background="#121722"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      SelectionChanged="TrustedRecipientsComboBox_SelectionChanged">
                                <ComboBox.Template>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton Focusable="False"
                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                          ClickMode="Press"
                                                          Background="#121722"
                                                          BorderBrush="{StaticResource BorderBrush}"
                                                          BorderThickness="1">
                                                <Grid>
                                                    <ContentPresenter Margin="12,0,34,0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Left"
                                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                          Width="8"
                                                          Height="4"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,14,0"
                                                          Fill="{StaticResource TextMutedBrush}" />
                                                </Grid>
                                            </ToggleButton>

                                            <Popup x:Name="PART_Popup"
                                                   AllowsTransparency="True"
                                                   Focusable="False"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   Placement="Bottom"
                                                   PopupAnimation="Slide">
                                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                        Background="#121722"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <ScrollViewer CanContentScroll="True">
                                                        <ItemsPresenter />
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </ComboBox.Template>

                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#121722" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#121722" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1B3A31" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F3F6FB" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F3F6FB" />
                                </ComboBox.Resources>

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#121722" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Setter Property="Padding" Value="12,8" />
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <Button x:Name="CheckRecipientButton"
                                    Grid.Column="2"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="150"
                                    Content="Check"
                                    Click="CheckRecipientButton_Click" />
                        </Grid>

                        <CheckBox x:Name="SendToSelfCheckBox"
                                  Margin="0,10,0,0"
                                  Content="Invia a me stesso"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontSize="14"
                                  Checked="SendToSelfCheckBox_Changed"
                                  Unchecked="SendToSelfCheckBox_Changed" />

                        <TextBlock x:Name="RecipientStatusTextBlock"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <TextBlock x:Name="RecipientFingerprintTextBlock"
                                   Margin="0,2,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <Border x:Name="DropZoneBorder"
                                Margin="0,8,0,0"
                                Height="135"
                                CornerRadius="8"
                                Background="#111827"
                                AllowDrop="True"
                                IsEnabled="False"
                                DragEnter="DropZoneBorder_DragEnter"
                                DragLeave="DropZoneBorder_DragLeave"
                                Drop="DropZoneBorder_Drop"
                                MouseLeftButtonUp="DropZoneBorder_MouseLeftButtonUp">
                            <Grid>
                                <Rectangle Stroke="#617089"
                                           StrokeThickness="2"
                                           StrokeDashArray="7,5"
                                           RadiusX="8"
                                           RadiusY="8"
                                           Fill="Transparent"
                                           IsHitTestVisible="False" />

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            MaxWidth="760">
                                    <TextBlock x:Name="DropZonePromptTextBlock"
                                               Text="Selezionare un destinatario"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" />

                                    <ScrollViewer Margin="0,12,0,0"
                                                  MaxHeight="58"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="SelectedFilesItemsControl"
                                                      HorizontalAlignment="Center">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Margin="0,3,0,0"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ListBox x:Name="SelectedFilesListBox"
                                 Visibility="Collapsed"
                                 Margin="0,14,0,0"
                                 MinHeight="84"
                                 MaxHeight="145"
                                 Background="#111827"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" />

                        <TextBlock x:Name="SelectedFilesStatusTextBlock"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <ProgressBar x:Name="SendProgressBar"
                                     Margin="0,12,0,0"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Visibility="Collapsed"
                                     Background="#111827"
                                     Foreground="{StaticResource PrimaryBrush}" />

                        <Button x:Name="SendEncryptedButton"
                                Margin="0,16,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="170"
                                HorizontalAlignment="Left"
                                Content="Invia"
                                IsEnabled="False"
                                Click="SendEncryptedButton_Click" />
                            </StackPanel>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="File in entrata" />
                                    <Ellipse x:Name="InboxPresenceIndicator"
                                             Width="9"
                                             Height="9"
                                             Margin="8,2,0,0"
                                             Fill="#AAB4C3" />
                                </StackPanel>
                            </TabItem.Header>

                            <StackPanel Margin="0,18,0,0">

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,14,0,0">
                            <Button x:Name="RefreshInboxButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="130"
                                    Content="Aggiorna"
                                    Click="RefreshInboxButton_Click" />

                            <Button x:Name="DownloadDecryptButton"
                                    Margin="12,0,0,0"
                                    Width="170"
                                    Content="Download"
                                    IsEnabled="False"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Click="DownloadDecryptButton_Click" />
                        </StackPanel>

                        <ListBox x:Name="InboxListBox"
                                 Margin="0,14,0,0"
                                 MinHeight="110"
                                 MaxHeight="170"
                                 Background="#111827"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 SelectionChanged="InboxListBox_SelectionChanged" />

                        <CheckBox x:Name="UseDefaultDownloadDirectoryCheckBox"
                                  Content="Salva nella default directory"
                                  Margin="0,12,0,0"
                                  FontSize="14"
                                  Foreground="{StaticResource TextMutedBrush}"
                                  Checked="UseDefaultDownloadDirectoryCheckBox_Changed"
                                  Unchecked="UseDefaultDownloadDirectoryCheckBox_Changed" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="DefaultDownloadDirectoryTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,12,0"
                                     Text="default directory"
                                     IsReadOnly="True"
                                     Foreground="{StaticResource TextMutedBrush}" />

                            <Button x:Name="ChooseDefaultDownloadDirectoryButton"
                                    Grid.Column="1"
                                    Width="190"
                                    Content="Scegli default directory"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Click="ChooseDefaultDownloadDirectoryButton_Click" />
                        </Grid>

                        <TextBlock x:Name="InboxStatusTextBlock"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <ProgressBar x:Name="InboxProgressBar"
                                     Margin="0,12,0,0"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Visibility="Collapsed"
                                     Background="#111827"
                                     Foreground="{StaticResource PrimaryBrush}" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>

                <!-- Hidden legacy controls still referenced by code-behind helpers. -->
                <Border x:Name="SidebarDetailPanel"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="SidebarDetailTitleTextBlock" />
                        <TextBlock x:Name="SidebarDetailStatusTextBlock" />
                        <ListBox x:Name="TrustedContactsListBox"
                                 SelectionChanged="TrustedContactsListBox_SelectionChanged" />
                        <Button x:Name="RemoveTrustedContactButton"
                                Click="RemoveTrustedContactButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
